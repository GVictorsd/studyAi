# Database
# SQLite (default – no server needed for local dev, data stored in studyai.db)
DATABASE_URL=sqlite+aiosqlite:///./studyai.db
# PostgreSQL (use this for Docker / production)
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/studyai

# Google AI / ADK
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=false

# Storage
STORAGE_BASE_PATH=./storage

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# App
APP_ENV=development
SECRET_KEY=change_this_to_a_random_secret_key
CORS_ORIGINS=http://localhost:4200,http://localhost:4202
# Multiple origins (comma-separated): CORS_ORIGINS=http://localhost:4200,http://localhost:3000,http://localhost:4202
